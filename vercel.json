{
  "version": 2,
  "public": true,
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/:file(.*\\.html)$",
      "destination": "/$1"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
