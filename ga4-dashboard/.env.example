# Required
GA4_PROPERTY_ID=123456789

# Option A: path to service account key JSON file
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\ga4-service-account.json

# Option B: direct env credentials (use one option only)
# GOOGLE_CLIENT_EMAIL=service-account@project-id.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

PORT=8787

# ─── Security (recommended in production) ───────────────────────
# Set BASIC_AUTH_USER + BASIC_AUTH_PASS to protect the /api/* surface.
# Without them and NODE_ENV=production, /api/* returns 503.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# Comma-separated list of origins allowed to call /api/* from a browser.
# Example: ALLOWED_ORIGINS=https://dashboard.efterplan.se,http://localhost:8787
ALLOWED_ORIGINS=
